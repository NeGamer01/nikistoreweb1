OKEPAY_BASE_URL=https://apipay.nikistore.biz.id/api.php
OKEPAY_API_KEY=isi_apikey_okepay
ORDER_SIGNING_SECRET=ganti_dengan_random_panjang
SITE_URL=https://domain-vercel-kamu.vercel.app
FONNTE_TOKEN=isi_token_dari_menu_device_fonnte
OWNER_WHATSAPP_NUMBER=628xxxxxxxxxx

DOWNLOAD_STARTER_STORE_URL=https://example.com/starter-store.zip
DOWNLOAD_WHATSAPP_BOT_URL=https://example.com/whatsapp-bot.zip
DOWNLOAD_DASHBOARD_SAAS_URL=https://example.com/dashboard-saas.zip
DOWNLOAD_TOPUP_PANEL_URL=https://example.com/topup-panel.zip

# Pterodactyl wrapper (sama untuk semua server)
WRAPPER_API_URL=https://wrapper-api-kamu.vercel.app

# Server 1 (lihat data/servers.json)
SERVER1_PTLA=ptla_xxx
SERVER1_PTLC=ptlc_xxx

# Server 2
SERVER2_PTLA=ptla_xxx
SERVER2_PTLC=ptlc_xxx

# MongoDB untuk tracking kuota panel per server
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=nikistore

# Toggle order panel (set "false" untuk sembunyikan tab & disable halaman)
NEXT_PUBLIC_PANEL_ORDERS_ENABLED=true

# Admin Dashboard
ADMIN_PASSWORD=ganti_dengan_password_admin_yang_kuat
ADMIN_SESSION_SECRET=ganti_dengan_random_string_panjang_minimal_32_char
